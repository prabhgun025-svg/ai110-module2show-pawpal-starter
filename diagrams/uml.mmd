classDiagram
    %% PawPal Pet Care App - Class Diagram
    %% Core domain model for scheduling and managing pet care tasks
    class PetOwner {
        -String owner_id
        -String name
        -String email
        +add_pet(pet)
        +remove_pet(pet_id)
        +get_pets()
        +generate_daily_schedule()
    }

    class Pet {
        String pet_id
        String name
        String species
        int age
        add_task(task)
        remove_task(task_id)
        get_tasks()
    }

    class Task {
        String task_id
        String name
        String duration_minutes
        String priority
        String recurrence
        bool is_completed
        toggle_complete()
        conflicts_with(other)
        is_overdue()
    }

    class Schedule {
        String schedule_id
        String date
        int total_minutes
        generate(tasks)
        add_slot(slot)
        remove_slot(slot_id)
        validate()
        display()
    }

    class ScheduleSlot {
        String start_time
        String end_time
        String reasoning_note
        get_duration()
        overlaps_with(other)
    }

    class Priority {
        <<enumeration>>
        HIGH
        MEDIUM
        LOW
    }

    class RecurrenceType {
        <<enumeration>>
        DAILY
        WEEKLY
        ONE_TIME
    }

    PetOwner "1" --> "*" Pet
    Pet "1" --> "*" Task
    Task --> Priority
    Task --> RecurrenceType
    Schedule "1" --> "*" ScheduleSlot
    Schedule --> PetOwner
    ScheduleSlot --> Task
    ScheduleSlot --> Pet

