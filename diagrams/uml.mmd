

    class PetOwner {
        +str owner_id
        +str name
        +str email
        +str phone
        +str address
        +list~Pet~ pets
        +add_pet(pet: Pet) None
        +remove_pet(pet_id: str) None
        +get_pets() list~Pet~
        +generate_daily_schedule() Schedule
    }

    class Pet {
        +str pet_id
        +str name
        +str species
        +str breed
        +int age
        +float weight
        +str medical_notes
        +list~Task~ tasks
        +add_task(task: Task) None
        +remove_task(task_id: str) None
        +get_tasks() list~Task~
        +get_tasks_by_priority(priority: Priority) list~Task~
    }

    class Task {
        +str task_id
        +str name
        +str description
        +int duration_minutes
        +Priority priority
        +RecurrenceType recurrence
        +time preferred_time
        +time deadline
        +bool is_completed
        +toggle_complete() None
        +conflicts_with(other: Task) bool
        +is_overdue() bool
    }

    class Priority {
        <<enumeration>>
        HIGH
        MEDIUM
        LOW
        +urgency_score() int
    }

    class RecurrenceType {
        <<enumeration>>
        DAILY
        WEEKLY
        ONE_TIME
    }

    class Schedule {
        +str schedule_id
        +date date
        +PetOwner owner
        +list~ScheduleSlot~ slots
        +list~Task~ skipped_tasks
        +int total_minutes
        +datetime generated_at
        +generate(tasks: list~Task~) None
        +add_slot(slot: ScheduleSlot) None
        +remove_slot(slot_id: str) None
        +validate() bool
        +display() str
        +get_reasoning() list~str~
        +get_skipped_tasks() list~Task~
    }

    class ScheduleSlot {
        +Task task
        +Pet pet
        +time start_time
        +time end_time
        +str reasoning_note
        +get_duration() int
        +overlaps_with(other: ScheduleSlot) bool
        +to_display_string() str
    }

    %% Associations
    PetOwner "1" --> "*" Pet : owns
    Pet "1" --> "*" Task : contains
    Task --> Priority : has
    Task --> RecurrenceType : has
    Schedule "1" --> "*" ScheduleSlot : contains
    Schedule --> PetOwner : generates for
    ScheduleSlot --> Task : schedules
