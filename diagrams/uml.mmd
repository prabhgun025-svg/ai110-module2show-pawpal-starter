classDiagram
    %% PawPal Pet Care App - Class Diagram
    %% Core domain model for scheduling and managing pet care tasks
    class PetOwner {
        String owner_id
        String name
        String email
        add_pet(pet)
        remove_pet(pet_id)
        get_pets()
        generate_daily_schedule()
    }

    class Pet {
        String pet_id
        String name
        String species
        int age
        String medical_notes
        add_task(task)
        remove_task(task_id)
        get_tasks()
    }

    class Task {
        String task_id
        String name
        String duration_minutes
        String priority
        String recurrence
        bool is_completed
        toggle_complete()
        conflicts_with(other)
        is_overdue()
    }

    class Schedule {
        String schedule_id
        String date
        int total_minutes
        generate(tasks)
        add_task(task)
        validate()
        display()
    }

    PetOwner "1" --> "*" Pet
    Pet "1" --> "*" Task
    Schedule "1" --> "1" PetOwner
    Schedule "1" --> "*" Task
